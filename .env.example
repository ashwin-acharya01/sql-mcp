# ─── Required ────────────────────────────────────────────────────────────────

# Database type: 'mssql' or 'pgsql'
DB_TYPE=pgsql

DB_HOST=localhost
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=postgres

# Default port: 5432 for pgsql, 1433 for mssql (can be omitted if using defaults)
DB_PORT=5432

# ─── Optional ────────────────────────────────────────────────────────────────

# Guard mode: 'confirm' (default) prompts before executing guarded operations.
# 'block' rejects them outright. Use 'block' for production environments.
GUARD_MODE=confirm

# Comma-separated list of SQL keywords that trigger the guard.
# Set to 'NONE' to disable guarding entirely (not recommended).
# Set to 'ALL' to use the full default list.
GUARDED_OPERATIONS=INSERT,UPDATE,DELETE,DROP,ALTER,TRUNCATE,EXEC,EXECUTE,MERGE,CREATE,GRANT,REVOKE,DENY

# ─── MSSQL-only ──────────────────────────────────────────────────────────────

# Set to 'true' when connecting to a local/dev SQL Server with a self-signed certificate.
# Leave unset or 'false' for production.
DB_TRUST_SERVER_CERTIFICATE=false
